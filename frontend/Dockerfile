# Stage 1: Build the application
FROM node:20-alpine AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci

COPY . .

ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Set Node memory limit for the build process (prevents 1GB RAM exhaustion on t3.micro)
ENV NODE_OPTIONS="--max-old-space-size=1024"

# Disable telemetry
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# Stage 2: Production image execution
FROM node:20-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Copy static assets and standard folders
COPY --from=builder /app/public ./public

# Set the correct permissions for Next cache
RUN mkdir .next
RUN chown node:node .next

# The standalone output copies exactly what is needed (avoids pulling massive node_modules)
COPY --from=builder --chown=node:node /app/.next/standalone ./
COPY --from=builder --chown=node:node /app/.next/static ./.next/static

USER node

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Running server.js generated by standalone mode uses much less memory
CMD ["node", "server.js"]
